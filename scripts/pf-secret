#!/usr/bin/env bash
# Narrow pf-secret client for GitHub-hosted CI.
#
# The repository's handbook refresh workflow assumes a least-privilege AWS
# role through GitHub OIDC, then uses the same pf-secret verb as every other
# PocketForge actor. Only read-only Secrets Manager access is needed here.

set -euo pipefail

die() {
  echo "pf-secret: $*" >&2
  exit 1
}

[[ "${1:-}" == "get" && $# -eq 2 ]] ||
  die "usage: pf-secret get <name>"

name="$2"
[[ "${name}" =~ ^[a-z0-9][a-z0-9/_-]*$ ]] ||
  die "invalid name '${name}'"
case "${name}" in
  */|/*|*//*|*..*) die "invalid name '${name}'" ;;
esac

[[ "${PF_SECRET_BACKEND:-}" == "aws-secrets" ]] ||
  die "PF_SECRET_BACKEND must be aws-secrets"

aws secretsmanager get-secret-value \
  --region "${AWS_REGION:-us-east-1}" \
  --secret-id "/pocketforge/${name}" \
  --query SecretString \
  --output text
